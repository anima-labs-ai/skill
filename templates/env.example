# Agent API key (ak_...) — create one in https://console.useanima.sh
ANIMA_API_KEY=ak_your_agent_key
# Optional: master key (mk_...) unlocks org-admin tools on the stdio server
# ANIMA_MASTER_KEY=mk_your_master_key
# Optional: API base URL override (defaults to https://api.useanima.sh)
# ANIMA_API_URL=https://api.useanima.sh
